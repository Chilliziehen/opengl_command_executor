}
class EnableCommand extends Command {
    - m_capability: uint32_t
    - m_enable: bool
    + execute(): void
}
class ClearColorCommand extends Command {
    - m_red,m_green,m_blue,m_alpha: float
    + execute(): void
}
class ClearCommand extends Command {
    - m_mask: uint32_t
