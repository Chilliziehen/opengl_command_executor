    + execute(): void
}
class ScissorCommand extends Command {
    - m_box: vector<int32_t>
    + execute(): void
}
class BlendFunctionCommand extends Command {
    - m_sourceFactor,m_destinationFactor: uint32_t
    + execute(): void
}
class BlendEquationCommand extends Command {
