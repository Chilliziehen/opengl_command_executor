}
CaptureVertexArrayObject *-- VertexAttribute

class CaptureFramebuffer <<struct>> {
    + m_framebufferId: uint32_t
    + m_label: string
    + m_attachments: vector<FramebufferAttachment>
}
class FramebufferAttachment <<struct>> {
    + m_attachmentPoint: uint32_t
    + m_textureId: uint32_t
