    + execute(): void
}
class DepthFunctionCommand extends Command {
    - m_function: uint32_t
    + execute(): void
}
class DepthMaskCommand extends Command {
    - m_enabled: bool
    + execute(): void
}
class ColorMaskCommand extends Command {
    - m_red,m_green,m_blue,m_alpha: bool
    + execute(): void
}
class LineWidthCommand extends Command {
