' ═══════════════════════════════════════════════════════════════════════════════
' SECTION 4: Capture Loader & FrameCapture (aggregation root)
' ═══════════════════════════════════════════════════════════════════════════════

class FrameCapture <<aggregate root>> {
    + m_manifest: CaptureManifest
    + m_buffers: vector<CaptureBuffer>
    + m_textures: vector<TextureWrapper>
    + m_shaders: vector<CaptureShader>
    + m_programs: vector<CaptureProgram>
    + m_vertexArrays: vector<CaptureVertexArrayObject>
    + m_framebuffers: vector<CaptureFramebuffer>
    + m_state: CaptureState
    + m_commands: vector<CommandPtr>
    --
    + findBuffer(id): const CaptureBuffer*
    + findTexture(id): const TextureWrapper*
    + findShader(id): const CaptureShader*
    + findProgram(id): const CaptureProgram*
    + findVertexArray(id): const CaptureVertexArrayObject*
    + findFramebuffer(id): const CaptureFramebuffer*
    + bufferCount(): size_t
    + textureCount(): size_t
    + shaderCount(): size_t
    + programCount(): size_t
    + vertexArrayCount(): size_t
    + framebufferCount(): size_t
    + commandCount(): size_t
    + clear(): void
}

FrameCapture *-- CaptureManifest
FrameCapture *-- CaptureBuffer
FrameCapture *-- TextureWrapper
FrameCapture *-- CaptureShader
FrameCapture *-- CaptureProgram
FrameCapture *-- CaptureVertexArrayObject
FrameCapture *-- CaptureFramebuffer
FrameCapture *-- CaptureState
FrameCapture o-- "CommandPtr" : owns commands

class CaptureLoader <<utility>> {
    {static} +loadFromDirectory(path, outCapture, outError): bool
    --
    {static} -parseManifest(path, outManifest, outError): bool
    {static} -parseBuffers(path, manifest, outBuffers, outError): bool
    {static} -parseTextures(path, manifest, outTextures, outError): bool
    {static} -parseShaders(path, manifest, outShaders, outError): bool
    {static} -parsePrograms(path, manifest, outPrograms, outError): bool
    {static} -parseVertexArrays(path, manifest, outVertexArrays, outError): bool
    {static} -parseFramebuffers(path, manifest, outFramebuffers, outError): bool
    {static} -parseState(path, manifest, outState, outError): bool
    {static} -parseCommands(path, manifest, outCommands, outError): bool
}
CaptureLoader ..> FrameCapture : populates
CaptureLoader ..> nlohmann_json : «uses»

' ═══════════════════════════════════════════════════════════════════════════════
' SECTION 5: Command Hierarchy (polymorphic, ~40 subclasses)
' ═══════════════════════════════════════════════════════════════════════════════

typedef "CommandPtr = unique_ptr<Command>" as CommandPtr

abstract class Command {
    # m_eventId: uint32_t
    # m_commandName: string
    # {static} s_captureDirectory: string
    --
    + Command(eventId, commandName)
    + getEventId(): uint32_t
    + getCommandName(): const string&
    + {abstract} execute(): void
    {static} +setCaptureDirectory(path): void
    # {static} captureDirectory(): const string&
}

' -- State Commands (no mapper lookup needed) --
