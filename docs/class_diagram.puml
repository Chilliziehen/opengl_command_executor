    - m_data: CommandDataArgument
    + execute(): void
}
class UniformSamplerCommand extends Command {
    - m_uniformName: string
    - m_programId,m_textureUnit: uint32_t
    - m_valueOmitted: bool
    + execute(): void
}

' -- Framebuffer --
class FramebufferTexture2DCommand extends Command {
    - m_framebufferId,m_attachment,m_textureTarget: uint32_t
    - m_textureId,m_mipmapLevel: uint32_t
    + execute(): void
}
class BlitFramebufferCommand extends Command {
    - m_sourceX0..m_destinationY1: int32_t
    - m_mask,m_filter: uint32_t
    + execute(): void
}

' -- No-Op --
class NoOpCommand extends Command {
    + execute(): void  // empty
}

' Command payload types
class UniformDataPayload <<variant>> {
    + m_arrayType: string
    + m_data: vector<double>
}
class UploadReference <<variant>> {
    + m_uploadPath: string
    + m_byteLength: uint64_t
}
typedef "CommandDataArgument\n= variant<UniformDataPayload,UploadReference,monostate>" as CommandDataArg

Command ..> CommandDataArg
BufferDataCommand ..> CommandDataArg
TextureImageCommand ..> CommandDataArg
UniformCommand ..> CommandDataArg
UniformMatrixCommand ..> CommandDataArg

