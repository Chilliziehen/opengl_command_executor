@startuml FrameReplayer_ClassDiagram
' =============================================================================
' Class Diagram — drawCommandsGL Frame Replayer
' =============================================================================
' Covers:
'   1. FrameCapture (aggregate root) and its data-struct members
'   2. Command polymorphism hierarchy (40+ GL command subclasses)
'   3. ResourceAllocator / ResourceManager (GPU lifecycle)
'   4. UniversalDMapper (capture-id ↔ GL-handle mapping)
'   5. ShaderInterpreter (GLSL 300 es → 410 core)
'   6. Singleton<Derived> (CRTP base)
' =============================================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 12
skinparam classBackgroundColor #F5F5F5
skinparam classBorderColor #333333
skinparam packageBackgroundColor #FAFAFA
title Frame Capture Replayer — Class Diagram

' ═══════════════════════════════════════════════════════════════════════════════
' SECTION 1: Infrastructure
' ═══════════════════════════════════════════════════════════════════════════════

class "Singleton<Derived>" <<CRTP>> {
    + {static} instance(): Derived&
    - Singleton()
    - ~Singleton()
    - Singleton(const Singleton&) = delete
    - operator=(const Singleton&) = delete
}
note right of "Singleton<Derived>"
  Thread-safe via C++11 magic statics.
  Used by UniversalDMapper.
end note

' ═══════════════════════════════════════════════════════════════════════════════
' SECTION 2: ID Mapping
' ═══════════════════════════════════════════════════════════════════════════════

class "UniversalDMapper<TKey,TVal>" <<singleton>> {
    + addMapping(key, val): void
    + getVal(key): TVal
    + getKey(val): TKey
    + containsKey(key): bool
    + containsVal(val): bool
    + removeMapping(key): void
    + clear(): void
    - m_mappingKeyToVal: unordered_map<TKey,TVal>
    - m_mappingValToKey: unordered_map<TVal,TKey>
}
"Singleton<Derived>" <|-- "UniversalDMapper<TKey,TVal>"

enum ResourceKind {
    Buffer = 1
    Texture = 2
    Shader = 3
    Program = 4
    VertexArray = 5
    Framebuffer = 6
}

typedef "ResourceMapper\n= UniversalDMapper<uint64_t>" as ResourceMapper

"UniversalDMapper<TKey,TVal>" ..> ResourceMapper : «typedef»

note right of ResourceMapper
  Global singleton.
  Key = encodeResourceKey(kind, captureId).
  High 8 bits = ResourceKind, low 56 bits = capture ID.
  Prevents collisions between resource types
  (e.g. texture #4 vs shader #4).
end note

' Free functions using ResourceMapper
class "MapperHelpers" <<utility>> {
    {static} +addMappedHandle(kind, captureId, glHandle): void
    {static} +getMappedHandle(kind, captureId): uint32_t
    {static} +hasMappedHandle(kind, captureId): bool
    {static} +removeMappedHandle(kind, captureId): void
    {static} +clearAllMappedHandles(): void
    {static} +getMappedHandleOr(kind, captureId, fallback): uint32_t
    {static} +encodeResourceKey(kind, captureId): uint64_t
}
MapperHelpers ..> ResourceMapper
MapperHelpers ..> ResourceKind

' ═══════════════════════════════════════════════════════════════════════════════
