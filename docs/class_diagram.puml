' SECTION 6: GPU Resource Management
' ═══════════════════════════════════════════════════════════════════════════════

class ResourceAllocator <<utility>> {
    {static} +allocateBuffer(metadata): uint32_t
    {static} +allocateTexture(metadata): uint32_t
    {static} +allocateShader(metadata): uint32_t
    {static} +allocateProgram(metadata): uint32_t
    {static} +allocateVertexArray(metadata): uint32_t
    {static} +allocateFramebuffer(metadata): uint32_t
    {static} +deleteBuffer(captureId): void
    {static} +deleteTexture(captureId): void
    {static} +deleteShader(captureId): void
    {static} +deleteProgram(captureId): void
    {static} +deleteVertexArray(captureId): void
    {static} +deleteFramebuffer(captureId): void
    {static} +allocateAllResources(capture, outError): bool
    {static} +deleteAllResources(capture): void
}
ResourceAllocator ..> ResourceMapper : registers handles
ResourceAllocator ..> ResourceKind
ResourceAllocator ..> "OpenGL\n(glad)" : calls glGen* / glDelete*

class ResourceManager <<utility>> {
    {static} +uploadBufferData(metadata, captureDir, outError): bool
    {static} +uploadTextureData(metadata, captureDir, isRenderTarget, outError): bool
    {static} +compileShader(metadata, outError): bool
    {static} +linkProgram(metadata, attributeBindings, outError): bool
    {static} +restoreState(capture, outError): bool
    {static} +restoreVertexArrays(capture, outError): bool
    {static} +restoreFramebuffers(capture, outError): bool
    {static} +uploadAllResources(capture, captureDir, outError): bool
}
ResourceManager ..> ResourceMapper : looks up handles
ResourceManager ..> ResourceKind
ResourceManager ..> "OpenGL\n(glad)" : calls gl* upload/bind/draw

' ═══════════════════════════════════════════════════════════════════════════════
' SECTION 7: Shader Translation
' ═══════════════════════════════════════════════════════════════════════════════

class ShaderInterpreter <<utility>> {
    {static} +translate(glslEs300Source, outError): string
    {static} +translateInPlace(source, outError): bool
    --
    {static} -replaceVersion(source): void
    {static} -removePrecisionStatements(source): void
    {static} -removePrecisionQualifiers(source): void
    {static} -removeExtensionDirectives(source): void
    {static} -addUboLayoutQualifier(source): void
    {static} -addFragmentOutputLayout(source): void
}
note right of ShaderInterpreter
  Regex-based translation:
  #version 300 es → #version 410 core
  Removes: precision, highp/mediump/lowp,
  #extension directives
  Adds: layout(std140) to UBO blocks
  (fragment output layout handled
  implicitly by GLSL 410 core)
end note

' ═══════════════════════════════════════════════════════════════════════════════
' SECTION 8: Relationships Between Major Components
' ═══════════════════════════════════════════════════════════════════════════════

' ResourceAllocator reads data structs to create GL objects
ResourceAllocator ..> CaptureBuffer
ResourceAllocator ..> TextureWrapper
ResourceAllocator ..> CaptureShader
ResourceAllocator ..> CaptureProgram
ResourceAllocator ..> CaptureVertexArrayObject
ResourceAllocator ..> CaptureFramebuffer

' ResourceManager reads data structs to upload data
ResourceManager ..> CaptureBuffer
ResourceManager ..> TextureWrapper
ResourceManager ..> CaptureShader
ResourceManager ..> CaptureProgram
ResourceManager ..> CaptureState
ResourceManager ..> CaptureVertexArrayObject
ResourceManager ..> CaptureFramebuffer
ResourceManager ..> ShaderInterpreter : calls translateInPlace()

' Command execution uses ResourceMapper and ResourceAllocator
Command ..> ResourceMapper : getMappedHandle / getMappedHandleOr
CreateResourceCommand ..> ResourceAllocator : allocate on-demand
DeleteResourceCommand ..> ResourceAllocator : delete on-demand

@enduml
