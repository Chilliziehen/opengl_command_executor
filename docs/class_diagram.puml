    + m_textureTarget: uint32_t
}
CaptureFramebuffer *-- FramebufferAttachment

class CaptureState <<struct>> {
    + m_currentProgramId: uint32_t
    + m_currentFramebufferId: uint32_t
    + m_currentActiveTextureUnit: uint32_t
    + m_currentArrayBufferId: uint32_t
    + m_currentElementArrayBufferId: uint32_t
    + m_currentVertexArrayId: uint32_t
    + m_currentTextureBindings: map<string,uint32_t>
    + m_currentSamplerBindings: map<string,map<string,uint32_t>>
    + m_vertexAttributes: map<string,VertexAttribute>
    + m_viewport: vector<int32_t>
    + m_capabilities: map<string,bool>
    + m_clearColor: vector<float>
    + m_clearDepth: float
    + m_clearStencil: int32_t
    + m_colorMask: vector<bool>
    + m_depthMask: bool
    + m_depthFunction: uint32_t
    + m_blendFunction: BlendFunction
    + m_blendEquation: BlendEquation
    + m_cullFaceMode: uint32_t
