    + m_compressed: bool
    + m_mipmapLevels: uint32_t
    + m_mipmapsGenerated: bool
    + m_deleted: bool
    + m_parameters: map<string,int32_t>
    + m_sourceKind: string
    + m_captureMethod: string
    + m_byteLength: uint64_t
    + m_capturedWidth: uint32_t
    + m_capturedHeight: uint32_t
    + m_capturedByteLength: uint64_t
    + m_hasBaselineBytes: bool
    + m_textureMetaPath: string
    + m_textureBinaryPath: string
}

class CaptureShader <<struct>> {
    + m_shaderId: uint32_t
