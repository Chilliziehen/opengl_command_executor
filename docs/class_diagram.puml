    + m_pixelStoreParameters: map<string,int32_t>
}
CaptureState *-- VertexAttribute

class CaptureManifest <<struct>> {
    + m_format: string
    + m_version: uint32_t
    + m_captureModel: string
    + m_generatedAt: string
    + m_frameIndex: uint32_t
    + m_canvas: CanvasDescriptor
    + m_replayerCompatibility: ReplayerCompatibility
